# Discord Bot Config
DISCORD_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CLIENT_SECRET=
DISCORD_INTENTS_MEMBERS=false
DISCORD_INTENTS_MESSAGE_CONTENT=false

# Email Verification (for /staffninja link)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=
LINK_CODE_TTL_MINUTES=10
LINK_CODE_MAX_ATTEMPTS=5

# PostgreSQL Config
POSTGRES_HOST=njas-sql-0002.postgres.database.azure.com
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=svc_nebkon
POSTGRES_PASSWORD=changeme
POSTGRES_SSL=require

# AI Provider Config
# Options: db_search (instant, no LLM), ollama, local_stub
AI_PROVIDER=db_search
AI_ENDPOINT=http://localhost:8000/v1
AI_MODEL=qwen2.5:3b
AI_REQUEST_TIMEOUT_SECONDS=120
AI_MAX_CONCURRENT_REQUESTS=2

# Logging
LOG_LEVEL=INFO

# Command resync interval (minutes)
COMMAND_RESYNC_MINUTES=30

# Chat monitor (auto-answers staff questions from policy docs)
CHAT_MONITOR_ENABLED=true
CHAT_MONITOR_CHANNELS=
CHAT_MONITOR_DOC_CATEGORIES=
CHAT_MONITOR_COOLDOWN_SECONDS=30
CHAT_MONITOR_USER_COOLDOWN_SECONDS=20
CHAT_MONITOR_MAX_QUESTION_CHARS=600

# Job queue
JOB_WORKER_POLL_SECONDS=5.0
JOB_STALE_TIMEOUT_SECONDS=600

# Google service account for Google Groups API
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json
GOOGLE_DELEGATED_ADMIN=conchair@animenebraskon.com
MAILINGLIST_GROUPS=staff@animenebraskon.com,leaders@animenebraskon.com
MAILINGLIST_PROTECTED_GROUPS=directors@animenebraskon.com
MAILINGLIST_LEADERSHIP_GROUP=leaders@animenebraskon.com
DISABLED_COMMANDS=

# Database Backups
DB_BACKUP_ENABLED=true
DB_BACKUP_DIR=/home/jsmith/staffNinja/backups
DB_BACKUP_HOUR=3

# Debugging
DEBUG_LOG_TO_DISCORD=false
